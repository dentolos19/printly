{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Server",
      "type": "shell",
      "command": "dotnet build '${workspaceFolder}/src/server/PrintlyServer.csproj' --configuration Debug",
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "Run Migrations",
      "type": "shell",
      "command": "pwsh -ExecutionPolicy Bypass -File migrate.ps1",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}/src/server"
      },
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "Add Migration",
      "type": "shell",
      "command": "pwsh -ExecutionPolicy Bypass -File migrate.ps1 -MigrationName ${input:migrationName}",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}/src/server"
      },
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Enter the name for the new migration",
      "default": "Migration"
    }
  ]
}
