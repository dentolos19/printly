{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Add Migration",
      "type": "shell",
      "command": "pwsh -ExecutionPolicy Bypass -File migrate.ps1 -MigrationName ${input:migrationName}",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}/src/server"
      },
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "Run Migrations",
      "type": "shell",
      "command": "pwsh -ExecutionPolicy Bypass -File migrate.ps1",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}/src/server"
      },
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "Force Migrations",
      "type": "shell",
      "command": "pwsh -ExecutionPolicy Bypass -File migrate.ps1 -Force",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}/src/server"
      },
      "presentation": {
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Enter the name for the new migration",
      "default": "Migration"
    }
  ]
}
