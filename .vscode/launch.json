{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "App",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/src/app",
      "command": "npm run dev",
      "serverReadyAction": {
        "pattern": "Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Server",
      "type": "coreclr",
      "request": "launch",
      "cwd": "${workspaceFolder}/src/server",
      "program": "${workspaceFolder}/src/server/bin/Debug/net10.0/PrintlyServer.dll",
      "preLaunchTask": "Build Server"
    }
  ],
  "compounds": [
    {
      "name": "App + Server",
      "configurations": ["Server", "App"]
    }
  ]
}
