{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "App",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}/src/app",
      "command": "npm run dev",
      "serverReadyAction": {
        "pattern": "Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Server",
      "request": "launch",
      "type": "coreclr",
      "cwd": "${workspaceFolder}/src/server",
      "program": "dotnet",
      "args": ["watch", "run"]
    }
  ],
  "compounds": [
    {
      "name": "App + Server",
      "configurations": ["App", "Server"],
      "stopAll": true
    }
  ]
}
